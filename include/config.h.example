#pragma once

// ---------------------------------------------------------------------------
// Wi-Fi credentials
// Copy this file to config.h and fill in your details.
// config.h is gitignored so your credentials stay off GitHub.
// ---------------------------------------------------------------------------

#define WIFI_SSID     "your_wifi_ssid"
#define WIFI_PASSWORD "your_wifi_password"

// NTP settings
#define NTP_SERVER    "pool.ntp.org"
#define NTP_OFFSET    -21600   // UTC offset in seconds (e.g. -21600 = UTC-6, Chicago)
#define NTP_INTERVAL  3600000  // Re-sync interval in ms (1 hour)

// Clock display settings
#define DISPLAY_BRIGHTNESS  4     // 0 (dim) to 7 (bright)
#define HOUR_FORMAT_24      false // false = 12-hour, true = 24-hour

// GPIO pin assignments
#define PIN_TM1637_CLK  22
#define PIN_TM1637_DIO  23
#define PIN_BTN_HOUR    18   // Button to increment hours (manual set)
#define PIN_BTN_MIN     19   // Button to increment minutes (manual set)
#define PIN_BUZZER      21   // Passive buzzer (optional, comment out to disable)
